{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "corepack pnpm --filter @industrial-dominion/api build",
    "watchPatterns": [
      "/apps/api/**",
      "/packages/shared/**",
      "/packages/config/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/turbo.json",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "corepack pnpm --filter @industrial-dominion/api start",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
