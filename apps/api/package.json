{
  "name": "@industrial-dominion/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src tests --max-warnings=0",
    "test": "vitest run tests",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\""
  },
  "dependencies": {
    "@industrial-dominion/config": "workspace:*",
    "@industrial-dominion/shared": "workspace:*",
    "fastify-plugin": "^5.0.1",
    "fastify": "^5.1.0",
    "@fastify/cors": "^10.0.1",
    "@supabase/supabase-js": "^2.49.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
