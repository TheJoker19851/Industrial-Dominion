{
  "name": "@industrial-dominion/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run tests --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"*.json\" \"*.ts\" \"*.cjs\" \"*.html\""
  },
  "dependencies": {
    "@industrial-dominion/shared": "workspace:*",
    "@industrial-dominion/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "react-i18next": "^15.1.0",
    "i18next": "^23.16.4",
    "@tanstack/react-query": "^5.59.20",
    "framer-motion": "^11.11.11",
    "recharts": "^2.13.0",
    "reactflow": "^11.11.4",
    "@supabase/supabase-js": "^2.49.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
